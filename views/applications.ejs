<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>My Applications | NextStep</title>

        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link rel="preconnect" href="https://api.fontshare.com" />
        <link
            href="https://fonts.googleapis.com/css2?family=Manrope:wght@500;700&display=swap"
            rel="stylesheet" />
        <link
            href="https://api.fontshare.com/v2/css?f[]=general-sans@400,500,600&display=swap"
            rel="stylesheet" />

        <link rel="stylesheet" href="/css/main.css" />
        <link rel="stylesheet" href="/css/applications.css" />
    </head>
    <body>
        <div class="page-shell">
            <header class="top-bar">
                <div class="top-bar__left">
                    <div class="top-bar__brand">
                        <%- include('partials/brand-logo') %>
                    </div>
                    <p class="top-bar__subtitle">Welcome back, <%= username %>.</p>
                </div>
                <div style="display: flex; gap: 1rem; align-items: center;">
                    <button
                        id="theme-toggle"
                        class="btn btn--ghost"
                        type="button"
                        aria-label="Toggle theme">
                        <svg
                            id="icon-moon"
                            xmlns="http://www.w3.org/2000/svg"
                            width="18"
                            height="18"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1.8"
                            stroke-linecap="round"
                            stroke-linejoin="round">
                            <path
                                d="M21 12.79A9 9 0 0 1 12.21 3 7 7 0 1 0 21 12.79z" />
                        </svg>
                        <svg
                            id="icon-sun"
                            xmlns="http://www.w3.org/2000/svg"
                            width="18"
                            height="18"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1.8"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            style="display: none;">
                            <circle cx="12" cy="12" r="4" />
                            <line x1="12" y1="2" x2="12" y2="5" />
                            <line x1="12" y1="19" x2="12" y2="22" />
                            <line x1="4.22" y1="4.22" x2="6.34" y2="6.34" />
                            <line x1="17.66" y1="17.66" x2="19.78" y2="19.78" />
                            <line x1="2" y1="12" x2="5" y2="12" />
                            <line x1="19" y1="12" x2="22" y2="12" />
                            <line x1="4.22" y1="19.78" x2="6.34" y2="17.66" />
                            <line x1="17.66" y1="6.34" x2="19.78" y2="4.22" />
                        </svg>
                    </button>
                    <a href="/auth/logout" class="btn btn--ghost">Logout</a>
                </div>
            </header>

            <% if (applications.length === 0) { %>
                <div class="empty-state">
                    <p>No applications yet.</p>
                    <a href="/applications/add">Add your first one!</a>
                </div>
            <% } else { %>
                <div class="card-grid">
                    <% applications.forEach(app => { %>
                        <div class="job-card">
                            <h3><%= app.company %></h3>
                            <p class="position"><%= app.position %></p>

                            <% if (app.job_link) { %>
                                <a href="<%= app.job_link %>" target="_blank">View Job Post</a>
                            <% } %>

                            <p class="date">Applied: <%= app.date_applied ? new Date(app.date_applied).toLocaleDateString() : 'N/A' %></p>

                            <span class="status-badge status-<%= app.status %>"><%= app.status %></span>

                            <div class="progress-dots">
                                <div class="dot-step">
                                    <span class="dot-label" data-active="<%= ['applied','interview','offer'].includes(app.status) ? 'active' : (app.status === 'rejected' ? 'rejected' : '') %>">Applied</span>
                                    <span class="dot<%= app.status === 'applied' ? ' current' : '' %>" data-active="<%= ['applied','interview','offer'].includes(app.status) ? 'active' : (app.status === 'rejected' ? 'rejected' : '') %>"></span>
                                </div>
                                <div class="dot-line" data-active="<%= ['interview','offer'].includes(app.status) ? 'active' : '' %>"></div>
                                <div class="dot-step">
                                    <span class="dot-label" data-active="<%= ['interview','offer'].includes(app.status) ? 'active' : '' %>">Interview</span>
                                    <span class="dot<%= app.status === 'interview' ? ' current' : '' %>" data-active="<%= ['interview','offer'].includes(app.status) ? 'active' : '' %>"></span>
                                </div>
                                <div class="dot-line" data-active="<%= app.status === 'offer' ? 'active' : '' %>"></div>
                                <div class="dot-step">
                                    <span class="dot-label" data-active="<%= app.status === 'offer' ? 'active' : '' %>">Offer</span>
                                    <span class="dot<%= app.status === 'offer' ? ' current' : '' %>" data-active="<%= app.status === 'offer' ? 'active' : '' %>"></span>
                                </div>
                            </div>

                            <div class="card-actions">
                                <a href="/applications/<%= app.id %>/edit">Edit</a>
                                <button class="btn-edit-status"
                                    data-id="<%= app.id %>"
                                    data-status="<%= app.status %>"
                                    data-applied-note="<%= app.applied_note || '' %>"
                                    data-interview-note="<%= app.interview_note || '' %>"
                                    data-offer-note="<%= app.offer_note || '' %>">
                                    Edit Status
                                </button>
                                <form action="/applications/<%= app.id %>/delete" method="POST">
                                    <button type="submit" class="btn-delete" onclick="return confirm('Delete this application?')">Delete</button>
                                </form>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } %>
        </div>
        <div class="modal-overlay" id="statusModal">
            <div class="modal">
                <div class="modal-header">
                    <h2>Update Status</h2>
                    <button type="button" class="modal-close" id="modalClose">&times;</button>
                </div>
                <form id="statusForm" method="POST">
                    <input type="hidden" name="status" id="statusInput" />

                    <div class="status-step" data-status="applied">
                        <div class="step-header">
                            <span class="step-radio"></span>
                            <span class="step-name">Applied</span>
                        </div>
                        <textarea name="applied_note" rows="2" placeholder="Add a note..."></textarea>
                    </div>

                    <div class="status-step" data-status="interview">
                        <div class="step-header">
                            <span class="step-radio"></span>
                            <span class="step-name">Interview</span>
                        </div>
                        <textarea name="interview_note" rows="2" placeholder="Add a note..."></textarea>
                    </div>

                    <div class="status-step" data-status="offer">
                        <div class="step-header">
                            <span class="step-radio"></span>
                            <span class="step-name">Offer</span>
                        </div>
                        <textarea name="offer_note" rows="2" placeholder="Add a note..."></textarea>
                    </div>

                    <div class="modal-quick-actions">
                        <button type="button" class="btn-quick btn-rejected" data-status="rejected">Rejected</button>
                        <button type="button" class="btn-quick btn-cancelled" data-status="cancelled">Cancelled</button>
                    </div>

                    <button type="submit" class="btn-save">Save Changes</button>
                </form>
            </div>
        </div>

        <script>
            document.querySelectorAll(".progress-dots").forEach(function (container) {
                var delay = 0;
                for (var i = 0; i < container.children.length; i++) {
                    var child = container.children[i];
                    if (child.classList.contains("dot-step")) {
                        var label = child.querySelector(".dot-label");
                        var dot = child.querySelector(".dot");
                        [label, dot].forEach(function (el) {
                            var cls = el.dataset.active;
                            if (cls) {
                                (function (element, className, d) {
                                    setTimeout(function () {
                                        element.classList.add(className);
                                    }, d);
                                })(el, cls, delay);
                            }
                        });
                        if (label.dataset.active) delay += 200;
                    } else if (child.classList.contains("dot-line") && child.dataset.active) {
                        (function (element, d) {
                            setTimeout(function () {
                                element.classList.add("active");
                            }, d);
                        })(child, delay);
                        delay += 150;
                    }
                }
            });

            var modal = document.getElementById("statusModal");
            var form = document.getElementById("statusForm");
            var statusInput = document.getElementById("statusInput");
            var steps = document.querySelectorAll(".status-step");
            var quickBtns = document.querySelectorAll(".btn-quick");
            function setActiveStatus(status) {
                statusInput.value = status;
                steps.forEach(function (s) {
                    s.classList.toggle("active", s.dataset.status === status);
                });
                quickBtns.forEach(function (b) {
                    b.classList.toggle("selected", b.dataset.status === status);
                });
            }

            document.querySelectorAll(".btn-edit-status").forEach(function (btn) {
                btn.addEventListener("click", function () {
                    form.action = "/applications/" + btn.dataset.id + "/status";
                    form.querySelector("[name='applied_note']").value = btn.dataset.appliedNote;
                    form.querySelector("[name='interview_note']").value = btn.dataset.interviewNote;
                    form.querySelector("[name='offer_note']").value = btn.dataset.offerNote;
                    setActiveStatus(btn.dataset.status);
                    modal.classList.add("visible");
                });
            });

            steps.forEach(function (step) {
                step.addEventListener("click", function () {
                    setActiveStatus(step.dataset.status);
                });
            });

            quickBtns.forEach(function (btn) {
                btn.addEventListener("click", function () {
                    setActiveStatus(btn.dataset.status);
                });
            });

        

            document.getElementById("modalClose").addEventListener("click", function () {
                modal.classList.remove("visible");
            });

            modal.addEventListener("click", function (e) {
                if (e.target === modal) {
                    modal.classList.remove("visible");
                }
            });

        </script>
    </body>
</html>
