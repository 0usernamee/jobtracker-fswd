<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>My Applications | NextStep</title>

        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400;500&family=Manrope:wght@500;700&display=swap"
            rel="stylesheet" />

        <link rel="stylesheet" href="/css/main.css" />
        <link rel="stylesheet" href="/css/applications.css" />
    </head>
    <body>
        <div class="page-shell">
            <header class="top-bar">
                <div>
                    <a href="/dashboard" class="subtle-link" style="text-decoration: none;">
                        <h1 class="top-bar__title">NextStep</h1>
                    </a>
                    <p class="top-bar__subtitle">Welcome back, <%= username %>.</p>
                </div>
                <div style="display: flex; gap: 1rem; align-items: center;">
                    <button
                        id="theme-toggle"
                        class="btn btn--ghost"
                        type="button"
                        aria-label="Toggle theme">
                        <svg
                            id="icon-moon"
                            xmlns="http://www.w3.org/2000/svg"
                            width="18"
                            height="18"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1.8"
                            stroke-linecap="round"
                            stroke-linejoin="round">
                            <path
                                d="M21 12.79A9 9 0 0 1 12.21 3 7 7 0 1 0 21 12.79z" />
                        </svg>
                        <svg
                            id="icon-sun"
                            xmlns="http://www.w3.org/2000/svg"
                            width="18"
                            height="18"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1.8"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            style="display: none;">
                            <circle cx="12" cy="12" r="4" />
                            <line x1="12" y1="2" x2="12" y2="5" />
                            <line x1="12" y1="19" x2="12" y2="22" />
                            <line x1="4.22" y1="4.22" x2="6.34" y2="6.34" />
                            <line x1="17.66" y1="17.66" x2="19.78" y2="19.78" />
                            <line x1="2" y1="12" x2="5" y2="12" />
                            <line x1="19" y1="12" x2="22" y2="12" />
                            <line x1="4.22" y1="19.78" x2="6.34" y2="17.66" />
                            <line x1="17.66" y1="6.34" x2="19.78" y2="4.22" />
                        </svg>
                    </button>
                    <a href="/auth/logout" class="btn btn--ghost">Logout</a>
                </div>
            </header>

            <% if (applications.length === 0) { %>
                <div class="empty-state">
                    <p>No applications yet.</p>
                    <a href="/applications/add">Add your first one!</a>
                </div>
            <% } else { %>
                <div class="card-grid">
                    <% applications.forEach(app => { %>
                        <div class="job-card">
                            <h3><%= app.company %></h3>
                            <p class="position"><%= app.position %></p>

                            <% if (app.job_link) { %>
                                <a href="<%= app.job_link %>" target="_blank">View Job Post</a>
                            <% } %>

                            <p class="date">Applied: <%= app.date_applied ? new Date(app.date_applied).toLocaleDateString() : 'N/A' %></p>

                            <span class="status-badge status-<%= app.status %>"><%= app.status %></span>

                            <div class="progress-dots">
                                <span class="dot <%= ['applied','interview','offer'].includes(app.status) ? 'active' : '' %>"></span>
                                <span class="dot <%= ['interview','offer'].includes(app.status) ? 'active' : '' %>"></span>
                                <span class="dot <%= app.status === 'offer' ? 'active' : '' %>"></span>
                            </div>

                            <div class="card-actions">
                                <a href="/applications/<%= app.id %>/edit">Edit</a>
                                <form action="/applications/<%= app.id %>/delete" method="POST">
                                    <button type="submit" class="btn-delete" onclick="return confirm('Delete this application?')">Delete</button>
                                </form>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } %>
        </div>
        <script>
            (function () {
                const prefersDark =
                    window.matchMedia &&
                    window.matchMedia("(prefers-color-scheme: dark)").matches;
                const stored = window.localStorage.getItem("nextstep-theme");
                const isDark = stored ? stored === "dark" : prefersDark;

                if (isDark) {
                    document.documentElement.classList.add("dark");
                }

                const btn = document.getElementById("theme-toggle");
                const iconMoon = document.getElementById("icon-moon");
                const iconSun = document.getElementById("icon-sun");

                function updateIcon() {
                    const dark = document.documentElement.classList.contains("dark");
                    if (iconMoon && iconSun) {
                        iconMoon.style.display = dark ? "none" : "inline-block";
                        iconSun.style.display = dark ? "inline-block" : "none";
                    }
                }

                updateIcon();

                if (btn) {
                    btn.addEventListener("click", function () {
                        document.documentElement.classList.toggle("dark");
                        const darkNow = document.documentElement.classList.contains("dark");
                        window.localStorage.setItem(
                            "nextstep-theme",
                            darkNow ? "dark" : "light",
                        );
                        updateIcon();
                    });
                }
            })();
        </script>
    </body>
</html>
