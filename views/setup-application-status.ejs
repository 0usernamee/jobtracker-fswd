<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Set Application Status | NextStep</title>

        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400;500&family=Manrope:wght@500;700&display=swap"
            rel="stylesheet" />

        <link rel="stylesheet" href="/css/main.css" />
        <link rel="stylesheet" href="/css/auth.css" />
        <link rel="stylesheet" href="/css/applications.css" />
    </head>
    <body>
        <div class="page-shell">
            <header class="top-bar">
                <div>
                    <a href="/dashboard" class="subtle-link" style="text-decoration: none;">
                        <h1 class="top-bar__title">NextStep</h1>
                    </a>
                </div>
                <div style="display: flex; gap: 1rem; align-items: center;">
                    <button
                        id="theme-toggle"
                        class="btn btn--ghost"
                        type="button"
                        aria-label="Toggle theme">
                        <svg
                            id="icon-moon"
                            xmlns="http://www.w3.org/2000/svg"
                            width="18"
                            height="18"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1.8"
                            stroke-linecap="round"
                            stroke-linejoin="round">
                            <path
                                d="M21 12.79A9 9 0 0 1 12.21 3 7 7 0 1 0 21 12.79z" />
                        </svg>
                        <svg
                            id="icon-sun"
                            xmlns="http://www.w3.org/2000/svg"
                            width="18"
                            height="18"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1.8"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            style="display: none;">
                            <circle cx="12" cy="12" r="4" />
                            <line x1="12" y1="2" x2="12" y2="5" />
                            <line x1="12" y1="19" x2="12" y2="22" />
                            <line x1="4.22" y1="4.22" x2="6.34" y2="6.34" />
                            <line x1="17.66" y1="17.66" x2="19.78" y2="19.78" />
                            <line x1="2" y1="12" x2="5" y2="12" />
                            <line x1="19" y1="12" x2="22" y2="12" />
                            <line x1="4.22" y1="19.78" x2="6.34" y2="17.66" />
                            <line x1="17.66" y1="6.34" x2="19.78" y2="4.22" />
                        </svg>
                    </button>
                    <a href="/auth/logout" class="btn btn--ghost">Logout</a>
                </div>
            </header>

            <main class="dashboard-grid">
                <section class="card" style="max-width: 560px; margin: 0 auto;">
                    <div class="list-header">
                        <div>
                            <h2 style="font-size: 1rem; margin: 0;">Set application status</h2>
                            <p style="margin: 0.5rem 0 0 0; color: var(--text-secondary);">
                                <strong><%= application.company %></strong> - <%= application.position %>
                            </p>
                        </div>
                        <a href="/applications" class="subtle-link">Skip for now</a>
                    </div>

                    <p style="margin: 0 0 1rem 0; color: var(--text-secondary);">
                        Your application was added. Choose its current stage and add any notes you want to save with it.
                    </p>

                    <form action="/applications/<%= application.id %>/status" method="POST" id="setupStatusForm">
                        <input type="hidden" name="status" id="statusInput" value="<%= application.status || 'applied' %>" />

                        <div class="status-step" data-status="applied">
                            <div class="step-header">
                                <span class="step-radio"></span>
                                <span class="step-name">Applied</span>
                            </div>
                            <textarea name="applied_note" rows="3" placeholder="Add an applied note..."><%= application.applied_note || '' %></textarea>
                        </div>

                        <div class="status-step" data-status="interview">
                            <div class="step-header">
                                <span class="step-radio"></span>
                                <span class="step-name">Interview</span>
                            </div>
                            <textarea name="interview_note" rows="3" placeholder="Add an interview note..."><%= application.interview_note || '' %></textarea>
                        </div>

                        <div class="status-step" data-status="offer">
                            <div class="step-header">
                                <span class="step-radio"></span>
                                <span class="step-name">Offer</span>
                            </div>
                            <textarea name="offer_note" rows="3" placeholder="Add an offer note..."><%= application.offer_note || '' %></textarea>
                        </div>

                        <div class="status-setup-actions">
                            <a href="/applications" class="btn btn--ghost">Skip for now</a>
                            <button type="submit" class="btn-save">Save Status</button>
                        </div>
                    </form>
                </section>
            </main>
        </div>

        <script>
            (function () {
                const prefersDark =
                    window.matchMedia &&
                    window.matchMedia("(prefers-color-scheme: dark)").matches;
                const stored = window.localStorage.getItem("nextstep-theme");
                const isDark = stored ? stored === "dark" : prefersDark;

                if (isDark) {
                    document.documentElement.classList.add("dark");
                }

                const btn = document.getElementById("theme-toggle");
                const iconMoon = document.getElementById("icon-moon");
                const iconSun = document.getElementById("icon-sun");

                function updateIcon() {
                    const dark = document.documentElement.classList.contains("dark");
                    if (iconMoon && iconSun) {
                        iconMoon.style.display = dark ? "none" : "inline-block";
                        iconSun.style.display = dark ? "inline-block" : "none";
                    }
                }

                updateIcon();

                if (btn) {
                    btn.addEventListener("click", function () {
                        document.documentElement.classList.toggle("dark");
                        const darkNow = document.documentElement.classList.contains("dark");
                        window.localStorage.setItem(
                            "nextstep-theme",
                            darkNow ? "dark" : "light"
                        );
                        updateIcon();
                    });
                }
            })();

            var statusInput = document.getElementById("statusInput");
            var steps = document.querySelectorAll(".status-step");

            function setActiveStatus(status) {
                statusInput.value = status;
                steps.forEach(function (step) {
                    step.classList.toggle("active", step.dataset.status === status);
                });
            }

            steps.forEach(function (step) {
                step.addEventListener("click", function () {
                    setActiveStatus(step.dataset.status);
                });
            });

            setActiveStatus(statusInput.value || "applied");
        </script>
    </body>
</html>
