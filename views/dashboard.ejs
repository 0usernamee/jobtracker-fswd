<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Dashboard | NextStep</title>

        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400;500&family=Manrope:wght@500;700&display=swap"
            rel="stylesheet" />

        <link rel="stylesheet" href="/css/main.css" />
        <link rel="stylesheet" href="/css/applications.css" />
    </head>
    <body>
        <div class="page-shell">
            <header class="top-bar">
                <div>
                    <a href="/dashboard" class="subtle-link" style="text-decoration: none;">
                        <h1 class="top-bar__title">NextStep</h1>
                    </a>
                </div>
                <div style="display: flex; gap: 1rem; align-items: center;">
                    <button
                        id="theme-toggle"
                        class="btn btn--ghost"
                        type="button"
                        aria-label="Toggle theme">
                        <svg
                            id="icon-moon"
                            xmlns="http://www.w3.org/2000/svg"
                            width="18"
                            height="18"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1.8"
                            stroke-linecap="round"
                            stroke-linejoin="round">
                            <path
                                d="M21 12.79A9 9 0 0 1 12.21 3 7 7 0 1 0 21 12.79z" />
                        </svg>
                        <svg
                            id="icon-sun"
                            xmlns="http://www.w3.org/2000/svg"
                            width="18"
                            height="18"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1.8"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            style="display: none;">
                            <circle cx="12" cy="12" r="4" />
                            <line x1="12" y1="2" x2="12" y2="5" />
                            <line x1="12" y1="19" x2="12" y2="22" />
                            <line x1="4.22" y1="4.22" x2="6.34" y2="6.34" />
                            <line x1="17.66" y1="17.66" x2="19.78" y2="19.78" />
                            <line x1="2" y1="12" x2="5" y2="12" />
                            <line x1="19" y1="12" x2="22" y2="12" />
                            <line x1="4.22" y1="19.78" x2="6.34" y2="17.66" />
                            <line x1="17.66" y1="6.34" x2="19.78" y2="4.22" />
                        </svg>
                    </button>
                    <a href="/auth/logout" class="btn btn--ghost">Logout</a>
                </div>
            </header>

            <main class="dashboard-grid">
                <section class="card">
                    <p class="top-bar__subtitle" style="margin-bottom: 0.75rem;">
                        Welcome back, <%= username %>.
                    </p>
                    <div class="list-header">
                        <div>
                            <span class="pill">Overview of job hunt</span>
                        </div>
                        <a href="/applications/add" class="btn btn--primary">+ Add application</a>
                    </div>

                    <div class="stats-grid">
                        <div class="stat-pill">
                            <span class="stat-pill__label">Applications</span>
                            <span class="stat-pill__value"><%= totalApplications || 0 %></span>
                        </div>
                        <div class="stat-pill">
                            <span class="stat-pill__label">Interviews</span>
                            <span class="stat-pill__value"><%= totalInterviews || 0 %></span>
                        </div>
                        <div class="stat-pill">
                            <span class="stat-pill__label">Rejections</span>
                            <span class="stat-pill__value"><%= totalRejections || 0 %></span>
                        </div>
                        <div class="stat-pill">
                            <span class="stat-pill__label">Offers</span>
                            <span class="stat-pill__value"><%= totalOffers || 0 %></span>
                        </div>
                    </div>
                </section>

                <section class="card">
                    <div class="list-header">
                        <h2 style="font-size: 1rem; margin: 0;">Recent applications</h2>
                        <a href="/applications" class="subtle-link">View all</a>
                    </div>

                    <% if (!recentApplications || recentApplications.length === 0) { %>
                        <p style="font-size: 0.9rem; opacity: 0.75;">
                            No applications yet. Start by adding your first one.
                        </p>
                    <% } else { %>
                        <div class="card-grid">
                            <% recentApplications.forEach(app => { %>
                                <div class="job-card">
                                    <% var activeNote = app.status === 'applied' ? app.applied_note : app.status === 'interview' ? app.interview_note : app.status === 'offer' ? app.offer_note : null; %>
                                    <% var activeStageLabel = app.status === 'applied' ? 'Applied' : app.status === 'interview' ? 'Interview' : app.status === 'offer' ? 'Offer' : app.status === 'rejected' ? 'Rejected' : app.status === 'cancelled' ? 'Cancelled' : 'Current'; %>
                                    <h3><%= app.company %></h3>
                                    <p class="position"><%= app.position %></p>

                                    <% if (app.job_link) { %>
                                        <a href="<%= app.job_link %>" target="_blank">View job post</a>
                                    <% } %>

                                    <p class="date">
                                        Applied:
                                        <%= app.date_applied ? new Date(app.date_applied).toLocaleDateString() : 'N/A' %>
                                    </p>

                                    <span class="status-badge status-<%= app.status %>">
                                        <%= app.status || 'applied' %>
                                    </span>

                                    <div class="progress-dots">
                                        <span
                                            class="dot <%= ['applied','interview','offer'].includes(app.status) ? 'active' : '' %>"></span>
                                        <span
                                            class="dot <%= ['interview','offer'].includes(app.status) ? 'active' : '' %>"></span>
                                        <span
                                            class="dot <%= app.status === 'offer' ? 'active' : '' %>"></span>
                                    </div>

                                    <div class="card-actions">
                                        <a href="/applications/<%= app.id %>/edit">Edit</a>
                                        <button
                                            class="btn-edit-status"
                                            data-id="<%= app.id %>"
                                            data-status="<%= app.status %>"
                                            data-applied-note="<%= app.applied_note || '' %>"
                                            data-interview-note="<%= app.interview_note || '' %>"
                                            data-offer-note="<%= app.offer_note || '' %>">
                                            Edit Status
                                        </button>
                                        <form action="/applications/<%= app.id %>/delete" method="POST">
                                            <button
                                                type="submit"
                                                class="btn-delete"
                                                onclick="return confirm('Delete this application?')">
                                                Delete
                                            </button>
                                        </form>
                                        <button
                                            type="button"
                                            class="btn-view-note"
                                            data-company="<%= app.company %>"
                                            data-stage="<%= activeStageLabel %>"
                                            data-note="<%= activeNote || '' %>">
                                            View Note
                                        </button>
                                    </div>
                                </div>
                            <% }) %>
                        </div>
                    <% } %>
                </section>
            </main>
        </div>
        <div class="modal-overlay" id="statusModal">
            <div class="modal">
                <div class="modal-header">
                    <h2>Update Status</h2>
                    <button type="button" class="modal-close" id="modalClose">&times;</button>
                </div>
                <form id="statusForm" method="POST">
                    <input type="hidden" name="status" id="statusInput" />

                    <div class="status-step" data-status="applied">
                        <div class="step-header">
                            <span class="step-radio"></span>
                            <span class="step-name">Applied</span>
                        </div>
                        <textarea name="applied_note" rows="2" placeholder="Add a note..."></textarea>
                    </div>

                    <div class="status-step" data-status="interview">
                        <div class="step-header">
                            <span class="step-radio"></span>
                            <span class="step-name">Interview</span>
                        </div>
                        <textarea name="interview_note" rows="2" placeholder="Add a note..."></textarea>
                    </div>

                    <div class="status-step" data-status="offer">
                        <div class="step-header">
                            <span class="step-radio"></span>
                            <span class="step-name">Offer</span>
                        </div>
                        <textarea name="offer_note" rows="2" placeholder="Add a note..."></textarea>
                    </div>

                    <div class="modal-quick-actions">
                        <button type="button" class="btn-quick btn-rejected" data-status="rejected">Rejected</button>
                        <button type="button" class="btn-quick btn-cancelled" data-status="cancelled">Cancelled</button>
                    </div>

                    <button type="submit" class="btn-save">Save Changes</button>
                </form>
            </div>
        </div>
        <div class="modal-overlay" id="noteModal">
            <div class="modal note-modal">
                <div class="modal-header">
                    <div>
                        <h2 id="noteModalTitle">Current Note</h2>
                        <p class="note-modal-stage" id="noteModalStage"></p>
                    </div>
                    <button type="button" class="modal-close" id="noteModalClose">&times;</button>
                </div>
                <div class="note-modal-body">
                    <p id="noteModalText"></p>
                </div>
                <button type="button" class="btn-save note-modal-close-btn" id="noteModalDone">Close</button>
            </div>
        </div>
        <script>
            (function () {
                const prefersDark =
                    window.matchMedia &&
                    window.matchMedia("(prefers-color-scheme: dark)").matches;
                const stored = window.localStorage.getItem("nextstep-theme");
                const isDark = stored ? stored === "dark" : prefersDark;

                if (isDark) {
                    document.documentElement.classList.add("dark");
                }

                const btn = document.getElementById("theme-toggle");
                const iconMoon = document.getElementById("icon-moon");
                const iconSun = document.getElementById("icon-sun");

                function updateIcon() {
                    const dark = document.documentElement.classList.contains("dark");
                    if (iconMoon && iconSun) {
                        iconMoon.style.display = dark ? "none" : "inline-block";
                        iconSun.style.display = dark ? "inline-block" : "none";
                    }
                }

                updateIcon();

                if (btn) {
                    btn.addEventListener("click", function () {
                        document.documentElement.classList.toggle("dark");
                        const darkNow = document.documentElement.classList.contains("dark");
                        window.localStorage.setItem(
                            "nextstep-theme",
                            darkNow ? "dark" : "light",
                        );
                        updateIcon();
                    });
                }
            })();

            var statusModal = document.getElementById("statusModal");
            var statusForm = document.getElementById("statusForm");
            var statusInput = document.getElementById("statusInput");
            var steps = document.querySelectorAll(".status-step");
            var quickBtns = document.querySelectorAll(".btn-quick");
            var noteModal = document.getElementById("noteModal");
            var noteModalTitle = document.getElementById("noteModalTitle");
            var noteModalStage = document.getElementById("noteModalStage");
            var noteModalText = document.getElementById("noteModalText");

            function setActiveStatus(status) {
                statusInput.value = status;
                steps.forEach(function (step) {
                    step.classList.toggle("active", step.dataset.status === status);
                });
                quickBtns.forEach(function (btn) {
                    btn.classList.toggle("selected", btn.dataset.status === status);
                });
            }

            document.querySelectorAll(".btn-edit-status").forEach(function (btn) {
                btn.addEventListener("click", function () {
                    statusForm.action = "/applications/" + btn.dataset.id + "/status";
                    statusForm.querySelector("[name='applied_note']").value = btn.dataset.appliedNote;
                    statusForm.querySelector("[name='interview_note']").value = btn.dataset.interviewNote;
                    statusForm.querySelector("[name='offer_note']").value = btn.dataset.offerNote;
                    setActiveStatus(btn.dataset.status);
                    statusModal.classList.add("visible");
                });
            });

            document.querySelectorAll(".btn-view-note").forEach(function (btn) {
                btn.addEventListener("click", function () {
                    noteModalTitle.textContent = btn.dataset.company + " Note";
                    noteModalStage.textContent = "Current stage: " + btn.dataset.stage;
                    noteModalText.textContent = btn.dataset.note || "No note saved for the current stage yet.";
                    noteModal.classList.add("visible");
                });
            });

            steps.forEach(function (step) {
                step.addEventListener("click", function () {
                    setActiveStatus(step.dataset.status);
                });
            });

            quickBtns.forEach(function (btn) {
                btn.addEventListener("click", function () {
                    setActiveStatus(btn.dataset.status);
                });
            });

            document.getElementById("modalClose").addEventListener("click", function () {
                statusModal.classList.remove("visible");
            });

            statusModal.addEventListener("click", function (e) {
                if (e.target === statusModal) {
                    statusModal.classList.remove("visible");
                }
            });

            document.getElementById("noteModalClose").addEventListener("click", function () {
                noteModal.classList.remove("visible");
            });

            document.getElementById("noteModalDone").addEventListener("click", function () {
                noteModal.classList.remove("visible");
            });

            noteModal.addEventListener("click", function (e) {
                if (e.target === noteModal) {
                    noteModal.classList.remove("visible");
                }
            });
        </script>
    </body>
</html>
